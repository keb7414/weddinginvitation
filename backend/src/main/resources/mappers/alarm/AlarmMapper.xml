<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.comes.invitation.alarm.AlarmMapper">

    <resultMap id="alarmResultMap" type="kr.comes.invitation.alarm.Alarm">
        <id     property="id"        column="id"/>
        <result property="contact"   column="contact"/>
        <result property="notifyAt"  column="notify_at"/>
        <result property="isSent"    column="is_sent"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO alarm (contact, notify_at)
        VALUES (#{contact}, #{notifyAt})
    </insert>

    <select id="findAll" resultMap="alarmResultMap">
        SELECT id, contact, notify_at, is_sent, created_at
          FROM alarm
         ORDER BY id DESC
    </select>
</mapper>
