<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.comes.invitation.guestbook.GuestbookMapper">

    <resultMap id="guestbookResultMap" type="kr.comes.invitation.guestbook.Guestbook">
        <id     property="id"        column="id"/>
        <result property="name"      column="name"/>
        <result property="message"   column="message"/>
        <result property="password"  column="password"/>
        <result property="isDeleted" column="is_deleted"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO guestbook (name, message, password)
        VALUES (#{name}, #{message}, #{password})
    </insert>

    <!-- 목록 — password 는 제외하고 조회 -->
    <select id="findAll" resultMap="guestbookResultMap">
        SELECT id, name, message, is_deleted, created_at
          FROM guestbook
         WHERE is_deleted = 0
         ORDER BY id DESC
    </select>

    <!-- 삭제 검증용 — password 포함 -->
    <select id="findById" resultMap="guestbookResultMap">
        SELECT id, name, message, password, is_deleted, created_at
          FROM guestbook
         WHERE id = #{id}
         LIMIT 1
    </select>

    <update id="softDelete">
        UPDATE guestbook
           SET is_deleted = 1
         WHERE id = #{id}
           AND is_deleted = 0
    </update>
</mapper>
