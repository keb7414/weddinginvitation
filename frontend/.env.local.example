# 로컬 개발용 — 이 파일을 복사해 .env.local 로 저장하고 값을 채우세요.
# (Supabase 콘솔 → Project Settings → API 에서 확인)

# 프로젝트 URL (예: https://abcdxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon public 키 (브라우저 노출 전제의 공개 키 — RLS 로 보호됨)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GitHub Pages 프로젝트 하위 경로. 로컬에선 비워두세요.
# (배포 시에는 워크플로가 /weddinginvitation 으로 주입)
# NEXT_PUBLIC_BASE_PATH=
